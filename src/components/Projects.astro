    // Matrix rain configuration
    const CHARS = "アァカサタナハマヤャラワガザダバパイィキシチニヒミリヰギジヂビピウゥクスツヌフムユュルグズブヅプエェケセテネヘメレヱゲゼデベペオォコソトノホモヨョロヲゴゾドボポヴッン0123456789";
    const FONT_SIZE = 14;
    let columns: number[] = [];
    let matrixRunning = false;
    let animationId: number | null = null;

    // Umbrella state
    let umbrellaX = 0;
    let umbrellaY = 0;
    const UMBRELLA_RADIUS = 50;
    let isDragging = false;
    let dragOffsetX = 0;
    let dragOffsetY = 0;

    function initMatrix() {
      const rect = matrixContainer.getBoundingClientRect();
      matrixCanvas.width = rect.width;
      matrixCanvas.height = rect.height;

      const colCount = Math.floor(matrixCanvas.width / FONT_SIZE);
      columns = Array(colCount).fill(1);

      // Center umbrella
      umbrellaX = matrixCanvas.width / 2 - UMBRELLA_RADIUS;
      umbrellaY = matrixCanvas.height / 2 - UMBRELLA_RADIUS;
      updateUmbrellaPosition();
    }

    function updateUmbrellaPosition() {
      umbrella.style.left = `${umbrellaX}px`;
      umbrella.style.top = `${umbrellaY}px`;
    }

    function drawMatrix() {
      // Semi-transparent black to create trail effect
      ctx.fillStyle = "rgba(0, 0, 0, 0.05)";
      ctx.fillRect(0, 0, matrixCanvas.width, matrixCanvas.height);

      ctx.fillStyle = "#00ff41";
      ctx.font = `${FONT_SIZE}px monospace`;

      const umbrellaCenterX = umbrellaX + UMBRELLA_RADIUS;
      const umbrellaCenterY = umbrellaY + UMBRELLA_RADIUS;

      for (let i = 0; i < columns.length; i++) {
        const char = CHARS[Math.floor(Math.random() * CHARS.length)];
        const x = i * FONT_SIZE;
        const y = columns[i] * FONT_SIZE;

        // Check if this drop is under the umbrella
        const dx = x - umbrellaCenterX;
        const dy = y - umbrellaCenterY;
        const distance = Math.sqrt(dx * dx + dy * dy);

        if (distance < UMBRELLA_RADIUS + 10 && y > umbrellaCenterY - UMBRELLA_RADIUS) {
          // Skip drawing under umbrella, or make it "splash"
          if (Math.random() > 0.8) {
            ctx.fillStyle = "rgba(0, 255, 65, 0.2)";
            ctx.fillText(char, x, umbrellaCenterY - UMBRELLA_RADIUS + 5);
            ctx.fillStyle = "#00ff41";
          }
          // Reset column to start from top
          if (y > umbrellaCenterY) {
            columns[i] = 0;
          }
        } else {
          // Vary brightness randomly for depth effect
          if (Math.random() > 0.95) {
            ctx.fillStyle = "#ffffff";
          } else if (Math.random() > 0.9) {
            ctx.fillStyle = "#88ff88";
          } else {
            ctx.fillStyle = "#00ff41";
          }
          ctx.fillText(char, x, y);
        }

        // Reset when reaching bottom or randomly
        if (y > matrixCanvas.height && Math.random() > 0.975) {
          columns[i] = 0;
        }
        columns[i]++;
      }

      if (matrixRunning) {
        animationId = requestAnimationFrame(drawMatrix);
      }
    }

