---
---

<section id="contact">
  <hr class="neon-divider" />
  <div class="section footer-section">
    <p class="section-label">Open Channel</p>
    <h2 class="section-title">
      Let's <span class="accent-cyan">Connect</span>
    </h2>

    <p class="footer-text">
      Incoming transmissions welcome. Pick a frequency.
    </p>

    <!-- Terminal-styled channel selector -->
    <div class="channel-panel">
      <div class="panel-header">
        <span class="panel-dot"></span>
        <span class="panel-title">OUTBOUND CHANNELS — 3 ACTIVE</span>
      </div>

      <div class="channel-list">
        <a href="https://www.linkedin.com/in/samuel-c-dyer/" target="_blank" rel="noopener noreferrer" class="channel channel--linkedin">
          <div class="channel-left">
            <span class="channel-indicator indicator--blue"></span>
            <div class="channel-info">
              <span class="channel-name">LinkedIn</span>
              <span class="channel-sub">Professional network · Experience · Resume</span>
            </div>
          </div>
          <div class="channel-right">
            <span class="channel-status">ONLINE</span>
            <span class="channel-arrow">↗</span>
          </div>
        </a>

        <a href="https://github.com/Dyerrate" target="_blank" rel="noopener noreferrer" class="channel channel--github">
          <div class="channel-left">
            <span class="channel-indicator indicator--green"></span>
            <div class="channel-info">
              <span class="channel-name">GitHub</span>
              <span class="channel-sub">Source code · Repos · Open-source work</span>
            </div>
          </div>
          <div class="channel-right">
            <span class="channel-status">ONLINE</span>
            <span class="channel-arrow">↗</span>
          </div>
        </a>

        <a href="mailto:dyerrate@gmail.com" class="channel channel--email">
          <div class="channel-left">
            <span class="channel-indicator indicator--cyan"></span>
            <div class="channel-info">
              <span class="channel-name">Email</span>
              <span class="channel-sub">Direct line · Inquiries · Collaboration</span>
            </div>
          </div>
          <div class="channel-right">
            <span class="channel-status">READY</span>
            <span class="channel-arrow">→</span>
          </div>
        </a>
      </div>

      <div class="panel-footer">
        <span>SIGNAL: STRONG</span>
        <span>LATENCY: &lt;1ms</span>
        <span>ENCRYPTION: ENABLED</span>
      </div>
    </div>

    <!-- Bottom decoration -->
    <div class="footer-bottom">
      <div class="footer-line" aria-hidden="true"></div>
      <div class="footer-meta">
        <span class="meta-item">© 2026 Samuel Dyer</span>
        <span class="meta-sep">//</span>
        <span class="meta-item">Built with Astro</span>
        <span class="meta-sep">//</span>
        <span class="meta-item">All systems nominal</span>
      </div>
      <div class="footer-ascii" aria-hidden="true">
        <pre>{`
  ╔══════════════════════════════════╗
  ║  END TRANSMISSION                ║
  ║  SIGNAL INTEGRITY: 100%          ║
  ║  THANK YOU FOR VISITING          ║
  ╚══════════════════════════════════╝`}</pre>
      </div>
    </div>
  </div>
</section>

<style>
  .accent-cyan {
    color: var(--col-neon-cyan);
    text-shadow: 0 0 20px rgba(0, 212, 255, 0.25);
  }

  .footer-section {
    padding-bottom: 60px;
  }

  .footer-text {
    max-width: 600px;
    font-size: 1.05rem;
    margin-bottom: 40px;
  }

  /* ── Channel Panel ── */
  .channel-panel {
    max-width: 640px;
    border: 1px solid var(--col-border);
    background: #0c0c10;
    overflow: hidden;
    margin-bottom: 80px;
  }

  .panel-header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 20px;
    background: #18181f;
    border-bottom: 1px solid var(--col-border);
  }

  .panel-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--col-neon-green);
    box-shadow: 0 0 6px rgba(0,255,65,0.4);
    animation: pulse-dot 2s ease infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .panel-title {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: var(--col-text-dim);
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  /* ── Channel rows ── */
  .channel-list {
    display: flex;
    flex-direction: column;
  }

  .channel {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 20px;
    border-bottom: 1px solid rgba(42,42,53,0.4);
    transition: all 0.25s ease;
    text-decoration: none;
    gap: 16px;
  }

  .channel:last-child {
    border-bottom: none;
  }

  .channel:hover {
    background: rgba(0,212,255,0.03);
    padding-left: 26px;
  }

  .channel-left {
    display: flex;
    align-items: center;
    gap: 14px;
    flex: 1;
  }

  .channel-indicator {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .indicator--blue {
    background: #0a96dc;
    box-shadow: 0 0 8px rgba(10,150,220,0.4);
  }

  .indicator--green {
    background: var(--col-neon-green);
    box-shadow: 0 0 8px rgba(0,255,65,0.4);
  }

  .indicator--cyan {
    background: var(--col-neon-cyan);
    box-shadow: 0 0 8px rgba(0,212,255,0.4);
  }

  .channel-info {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .channel-name {
    font-family: var(--font-mono);
    font-size: 0.88rem;
    color: var(--col-heading);
    letter-spacing: 0.08em;
    font-weight: 500;
  }

  .channel-sub {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--col-text-dim);
    letter-spacing: 0.1em;
  }

  .channel-right {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }

  .channel-status {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    color: var(--col-neon-green);
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .channel-arrow {
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--col-text-dim);
    transition: transform 0.2s, color 0.2s;
  }

  .channel:hover .channel-arrow {
    color: var(--col-neon-cyan);
    transform: translateX(3px);
  }

  .channel--linkedin:hover .channel-name { color: #0a96dc; }
  .channel--github:hover .channel-name { color: var(--col-neon-green); }
  .channel--email:hover .channel-name { color: var(--col-neon-cyan); }

  .channel--linkedin:hover .channel-status { color: #0a96dc; }
  .channel--github:hover .channel-status { color: var(--col-neon-green); }
  .channel--email:hover .channel-status { color: var(--col-neon-cyan); }

  /* ── Panel Footer ── */
  .panel-footer {
    display: flex;
    justify-content: space-between;
    padding: 10px 20px;
    border-top: 1px solid var(--col-border);
    background: #18181f;
    font-family: var(--font-mono);
    font-size: 0.52rem;
    color: var(--col-text-dim);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.5;
  }

  /* ── Bottom ── */
  .footer-bottom {
    margin-top: 40px;
  }

  .footer-line {
    height: 1px;
    background: var(--col-border);
    margin-bottom: 24px;
  }

  .footer-meta {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--col-text-dim);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }

  .meta-sep {
    color: var(--col-border);
  }

  .footer-ascii {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--col-border);
    line-height: 1.4;
    opacity: 0.5;
  }

  .footer-ascii pre {
    margin: 0;
    font-family: inherit;
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .channel {
      flex-direction: column;
      align-items: flex-start;
      gap: 10px;
    }

    .channel-right {
      align-self: flex-end;
    }

    .panel-footer {
      flex-direction: column;
      gap: 4px;
      text-align: center;
    }
  }
</style>

