<!-- File system navigation + scroll-triggered boot script -->
<script>
  import * as THREE from "three";

  document.addEventListener("DOMContentLoaded", () => {
    const CHAR_SPEED = 22;
    const LINE_PAUSE = 200;

    // Elements
    const section = document.getElementById("projects") as HTMLElement;
    const loadingEl = document.getElementById("terminalLoading") as HTMLElement;
    const bootEl = document.getElementById("terminalBoot") as HTMLElement;
    const mainEl = document.getElementById("terminalMain") as HTMLElement;
    const viewRoot = document.getElementById("viewRoot") as HTMLElement;
    const viewSubSpatial = document.getElementById("viewSubSpatial") as HTMLElement;
    const viewSubSpatialReadme = document.getElementById("viewSubSpatialReadme") as HTMLElement;
    const viewAutoCar = document.getElementById("viewAutoCar") as HTMLElement;
    const backBtn = document.getElementById("backBtn") as HTMLElement;
    const terminalTitle = document.getElementById("terminalTitle") as HTMLElement;
    const terminalPath = document.getElementById("terminalPath") as HTMLElement;

    let hasBooted = false;

    // ── Typewriter utility ──
    function typeText(el: HTMLElement, text: string, speed: number): Promise<void> {
      return new Promise((resolve) => {
        let i = 0;
        const cursor = document.createElement("span");
        cursor.className = "boot-cursor";
        cursor.textContent = "\u2588";
        el.appendChild(cursor);

        function tick() {
          if (i < text.length) {
            cursor.remove();
            el.insertAdjacentText("beforeend", text[i]);
            el.appendChild(cursor);
            i++;
            setTimeout(tick, speed);
          } else {
            cursor.remove();
            resolve();
          }
        }
        tick();
      });
    }

    function sleep(ms: number): Promise<void> {
      return new Promise((r) => setTimeout(r, ms));
    }

    // ── Boot sequence ──
    async function runBoot() {
      loadingEl.classList.add("hidden");
      bootEl.classList.remove("hidden");

      const lines = [
        { text: "sdyer@creative-lab:~$ cd projects", color: "green" },
        { text: "sdyer@creative-lab:~/projects$ ls -la", color: "green" },
        { text: "total 5 entries", color: "dim" },
        { text: "drwxr-xr-x  4 sdyer  staff  128 Mar 24 09:41 .", color: "dim" },
        { text: "drwxr-xr-x  8 sdyer  staff  256 Mar 24 09:41 ..", color: "dim" },
        { text: "drwxr-xr-x  6 sdyer  staff  2.4G  ACTIVE  Sub_Spatial_Studio/", color: "cyan" },
        { text: "drwxr-xr-x  5 sdyer  staff  1.8G  IN_DEV  AutoCar_VR/", color: "cyan" },
        { text: "drwxr-xr-x  3 sdyer  staff  4.2M  DEMO    matrix/", color: "matrix" },
        { text: "drwxr-xr-x  3 sdyer  staff  2.1M  DEMO    pretext_matrix/", color: "pretext" },
        { text: "-r?x--x---  ? sdyer  staff  ?.??G  ??????  AI_Agriculture.exe", color: "red" },
      ];

      for (const line of lines) {
        const p = document.createElement("p");
        p.className = `boot-line boot-line--${line.color}`;
        bootEl.appendChild(p);
        await typeText(p, line.text, CHAR_SPEED);
        await sleep(LINE_PAUSE);
      }

      await sleep(400);

      // Transition: fade boot out, show main content
      bootEl.style.transition = "opacity 0.4s ease";
      bootEl.style.opacity = "0";
      await sleep(400);
      bootEl.classList.add("hidden");
      mainEl.classList.remove("hidden");
      mainEl.style.animation = "fadeSlideIn 0.4s ease forwards";
    }

    // ── IntersectionObserver: trigger boot on scroll ──
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && !hasBooted) {
            hasBooted = true;
            observer.disconnect();
            runBoot();
          }
        });
      },
      { threshold: 0.15 }
    );

    observer.observe(section);

    // ── File system navigation ──
    const viewMatrix = document.getElementById("viewMatrix") as HTMLElement;
    const viewPretextMatrix = document.getElementById("viewPretextMatrix") as HTMLElement;
    const viewConnectz = document.getElementById("viewConnectz") as HTMLElement;
    const views: Record<string, HTMLElement> = {
      root: viewRoot,
      subSpatial: viewSubSpatial,
      subSpatialReadme: viewSubSpatialReadme,
      autoCar: viewAutoCar,
      matrix: viewMatrix,
      pretextMatrix: viewPretextMatrix,
      connectz: viewConnectz,
    };

    const titles: Record<string, string> = {
      root: "sdyer@creative-lab:~/projects",
      subSpatial: "sdyer@creative-lab:~/projects/Sub_Spatial_Studio",
      subSpatialReadme: "sdyer@creative-lab:~/projects/Sub_Spatial_Studio/README.md",
      autoCar: "sdyer@creative-lab:~/projects/AutoCar_VR",
      matrix: "sdyer@creative-lab:~/projects/matrix",
      pretextMatrix: "sdyer@creative-lab:~/projects/pretext_matrix",
      connectz: "sdyer@creative-lab:~/projects/Sub_Spatial_Studio/Connectz.md",
    };

    const pathLabels: Record<string, string> = {
      subSpatial: "Sub_Spatial_Studio",
      subSpatialReadme: "README.md",
      autoCar: "AutoCar_VR",
      matrix: "matrix",
      pretextMatrix: "pretext_matrix",
      connectz: "Connectz.md",
    };

    // Parent map for nested navigation (used by breadcrumbs + back button)
    const parents: Record<string, string | null> = {
      root: null,
      subSpatial: "root",
      subSpatialReadme: "subSpatial",
      autoCar: "root",
      matrix: "root",
      pretextMatrix: "root",
      connectz: "subSpatial",
    };

    let currentKey: string = "root";

    // Matrix control functions (defined later, referenced here)
    let startMatrix: (() => void) | null = null;
    let stopMatrix: (() => void) | null = null;

    // Pretext control functions (defined later, referenced here)
    let startPretext: (() => void) | null = null;
    let stopPretext: (() => void) | null = null;

    // Connectz control functions (defined later, referenced here)
    let startConnectz: (() => void) | null = null;
    let stopConnectz: (() => void) | null = null;

    function buildBreadcrumb(key: string): string {
      // Walk up the parents chain to build the full path
      const chain: string[] = [];
      let cursor: string | null = key;
      while (cursor) {
        chain.unshift(cursor);
        cursor = parents[cursor] ?? null;
      }

      const parts: string[] = [];
      chain.forEach((k, i) => {
        const isLast = i === chain.length - 1;
        if (k === "root") {
          parts.push(`<span class="path-segment path-root" data-nav="root">~/projects</span>`);
        } else if (isLast) {
          parts.push(`<span class="path-segment path-current">${pathLabels[k]}</span>`);
        } else {
          parts.push(`<span class="path-segment path-link" data-nav="${k}">${pathLabels[k]}</span>`);
        }
      });
      return parts.join('<span class="path-sep">/</span>');
