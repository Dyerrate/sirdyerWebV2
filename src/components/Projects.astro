      if (stopMatrix) stopMatrix();
      if (stopPretext) stopPretext();
      if (stopConnectz) stopConnectz();

      currentKey = key;

      Object.values(views).forEach((v) => v.classList.add("hidden"));
      views[key].classList.remove("hidden");
      views[key].style.animation = "fadeSlideIn 0.35s ease forwards";
      terminalTitle.textContent = titles[key];

      terminalPath.innerHTML = buildBreadcrumb(key);
      if (key === "root") {
        backBtn.classList.add("hidden");
      } else {
        backBtn.classList.remove("hidden");
      }

      // Start matrix animation when entering that view
      if (key === "matrix" && startMatrix) {
        setTimeout(startMatrix, 100);
      }

      // Start pretext animation when entering that view
      if (key === "pretextMatrix" && startPretext) {
        setTimeout(startPretext, 100);
      }

      // Start connectz globe animation when entering that view
      if (key === "connectz" && startConnectz) {
        setTimeout(startConnectz, 100);
      }

      // Wire up clickable breadcrumb segments (root + intermediate parents)
      terminalPath.querySelectorAll<HTMLElement>("[data-nav]").forEach((el) => {
        const navKey = el.dataset.nav;
        if (navKey) el.addEventListener("click", () => showView(navKey));
      });
