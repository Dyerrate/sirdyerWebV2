---
---

<section id="hero" class="hero">
  <!-- Animated grid background -->
  <div class="hero-grid" aria-hidden="true"></div>

  <!-- Decorative wireframe ring -->
  <div class="wireframe-ring" aria-hidden="true">
    <svg viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg">
      <ellipse
        cx="200"
        cy="200"
        rx="180"
        ry="60"
        fill="none"
        stroke="var(--col-neon-green)"
        stroke-width="0.5"
        opacity="0.2"
      />
      <ellipse
        cx="200"
        cy="200"
        rx="140"
        ry="140"
        fill="none"
        stroke="var(--col-neon-cyan)"
        stroke-width="0.3"
        opacity="0.15"
        stroke-dasharray="8 4"
      />
      <ellipse
        cx="200"
        cy="200"
        rx="60"
        ry="180"
        fill="none"
        stroke="var(--col-neon-green)"
        stroke-width="0.5"
        opacity="0.15"
      />
      <circle
        cx="200"
        cy="200"
        r="4"
        fill="var(--col-neon-green)"
        opacity="0.6"
      />
    </svg>
  </div>

  <div class="hero-content">
    <p class="hero-prefix">
      <span class="blink">▸</span> INIT: PORTFOLIO_v2.6 — STATUS: LOADED
    </p>

    <h1 class="hero-name">
      Samuel<br />
      <span class="hero-name-accent">Dyer</span>
    </h1>

    <p class="hero-tagline">
      Engineer. Creative Technologist.<br />
      <span class="highlight-cyan">Building at the boundary between code &amp; immersive reality.</span>
    </p>

    <div class="hero-tags">
      <span class="tag">AR / VR</span>
      <span class="tag">Spatial Computing</span>
      <span class="tag">Creative Code</span>
      <span class="tag">Immersive Experiences</span>
    </div>

    <div class="hero-cta">
      <a href="#vision" class="cta-primary">
        <span class="cta-icon">◈</span> Explore My Vision
      </a>
      <a href="#contact" class="cta-secondary">Establish Link →</a>
    </div>
  </div>

  <!-- Scrolling data strip -->
  <div class="data-strip" aria-hidden="true">
    <div class="data-strip-inner">
      LATITUDE: 37.7749° N — LONGITUDE: 122.4194° W — SECTOR: CREATIVE_TECH — CLEARANCE: OPEN_SOURCE — SIGNAL: STRONG — FREQ: 432Hz — PROTOCOL: SPATIAL_v3 —&nbsp;
      LATITUDE: 37.7749° N — LONGITUDE: 122.4194° W — SECTOR: CREATIVE_TECH — CLEARANCE: OPEN_SOURCE — SIGNAL: STRONG — FREQ: 432Hz — PROTOCOL: SPATIAL_v3 —&nbsp;
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    overflow: hidden;
    padding-top: 56px;
  }

  /* ── Grid BG ── */
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(
        rgba(0, 255, 65, 0.04) 1px,
        transparent 1px
      ),
      linear-gradient(
        90deg,
        rgba(0, 255, 65, 0.04) 1px,
        transparent 1px
      );
    background-size: 60px 60px;
    mask-image: radial-gradient(
      ellipse at center,
      black 30%,
      transparent 70%
    );
  }

  /* ── Wireframe ring ── */
  .wireframe-ring {
    position: absolute;
    top: 50%;
    right: -5%;
    width: 500px;
    height: 500px;
    transform: translateY(-50%);
    animation: spin-slow 60s linear infinite;
    opacity: 0.6;
  }

  @keyframes spin-slow {
    to {
      transform: translateY(-50%) rotate(360deg);
    }
  }

  /* ── Content ── */
  .hero-content {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
    position: relative;
    z-index: 2;
  }

  .hero-prefix {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--col-neon-green);
    letter-spacing: 0.2em;
    margin-bottom: 24px;
  }

  .blink {
    animation: blink-cursor 1s step-end infinite;
  }

  @keyframes blink-cursor {
    50% {
      opacity: 0;
    }
  }

  .hero-name {
    font-size: clamp(3rem, 10vw, 7rem);
    font-weight: 900;
    letter-spacing: 0.06em;
    line-height: 0.95;
    margin-bottom: 24px;
    color: var(--col-heading);
  }

  .hero-name-accent {
    color: var(--col-neon-green);
    text-shadow:
      0 0 20px rgba(0, 255, 65, 0.3),
      0 0 60px rgba(0, 255, 65, 0.1);
  }

  .hero-tagline {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2.5vw, 1.35rem);
    font-weight: 300;
    color: var(--col-text);
    max-width: 560px;
    margin-bottom: 32px;
  }

  .highlight-cyan {
    color: var(--col-neon-cyan);
  }

  /* ── Tags ── */
  .hero-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 40px;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--col-neon-cyan);
    border: 1px solid rgba(0, 212, 255, 0.25);
    padding: 4px 14px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    background: rgba(0, 212, 255, 0.04);
  }

  /* ── CTA ── */
  .hero-cta {
    display: flex;
    align-items: center;
    gap: 28px;
    flex-wrap: wrap;
  }

  .cta-primary {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 12px 28px;
    border: 1px solid var(--col-neon-green);
    color: var(--col-neon-green);
    background: rgba(0, 255, 65, 0.05);
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .cta-primary:hover {
    background: rgba(0, 255, 65, 0.12);
    box-shadow:
      0 0 20px rgba(0, 255, 65, 0.15),
      inset 0 0 20px rgba(0, 255, 65, 0.05);
    color: var(--col-neon-green);
  }

  .cta-secondary {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--col-text-dim);
  }

  .cta-secondary:hover {
    color: var(--col-neon-cyan);
  }

  /* ── Data strip ── */
  .data-strip {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    overflow: hidden;
    border-top: 1px solid var(--col-border);
    background: rgba(10, 10, 12, 0.6);
    padding: 6px 0;
  }

  .data-strip-inner {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--col-text-dim);
    letter-spacing: 0.2em;
    white-space: nowrap;
    animation: scroll-strip 30s linear infinite;
  }

  @keyframes scroll-strip {
    to {
      transform: translateX(-50%);
    }
  }

  @media (max-width: 768px) {
    .wireframe-ring {
      width: 300px;
      height: 300px;
      right: -15%;
      opacity: 0.3;
    }

    .hero-cta {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }
  }
</style>
