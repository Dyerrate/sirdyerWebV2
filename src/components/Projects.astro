      needsRedraw = true;
    }

    // Check if a point is inside the umbrella's exclusion zone
    function isInsideUmbrella(x: number, y: number): boolean {
      const centerX = pretextUmbrellaX + PRETEXT_UMBRELLA_RADIUS;
      const centerY = pretextUmbrellaY + PRETEXT_UMBRELLA_RADIUS;
      const dx = x - centerX;
      const dy = y - centerY;
      return Math.sqrt(dx * dx + dy * dy) < PRETEXT_UMBRELLA_RADIUS + 15;
    }

    // Get the horizontal bounds for text at a given y position
    function getLineBounds(y: number): { left: number; right: number }[] {
      const centerX = pretextUmbrellaX + PRETEXT_UMBRELLA_RADIUS;
      const centerY = pretextUmbrellaY + PRETEXT_UMBRELLA_RADIUS;
      const radius = PRETEXT_UMBRELLA_RADIUS + 15;
      
      // Check if this line intersects the umbrella circle
      const dy = Math.abs(y - centerY);
      if (dy > radius) {
        // No intersection, full width available
        return [{ left: 10, right: pretextCanvas.width - 10 }];
      }
      
      // Calculate intersection points
      const halfChord = Math.sqrt(radius * radius - dy * dy);
      const leftIntersect = centerX - halfChord;
      const rightIntersect = centerX + halfChord;
      
      // Return segments avoiding the umbrella
      const segments: { left: number; right: number }[] = [];
      if (leftIntersect > 15) {
        segments.push({ left: 10, right: leftIntersect - 5 });
      }
      if (rightIntersect < pretextCanvas.width - 15) {
        segments.push({ left: rightIntersect + 5, right: pretextCanvas.width - 10 });
      }
      
      return segments.length > 0 ? segments : [];
    }

    function drawPretext() {
      // Always redraw for rain animation
      rainTime += 0.03;

      // Clear canvas
