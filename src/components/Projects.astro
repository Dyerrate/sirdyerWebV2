---
---

<section id="projects">
  <hr class="neon-divider" />
  <div class="section">
    <p class="section-label">Transmissions</p>
    <h2 class="section-title">
      Creative <span class="accent-green">Explorations</span>
    </h2>

    <p class="proj-intro">
      Beyond the day job, these are the ideas I chase — studios, prototypes,
      and provocations at the edge of immersive technology.
      Navigate the file system below to explore.
    </p>

    <!-- Retro terminal file browser -->
    <div class="terminal-window">
      <!-- Title bar -->
      <div class="terminal-titlebar">
        <div class="titlebar-dots">
          <span class="dot dot--red"></span>
          <span class="dot dot--yellow"></span>
          <span class="dot dot--green"></span>
        </div>
        <span class="titlebar-text" id="terminalTitle">sdyer@creative-lab:~/projects</span>
        <span class="titlebar-spacer"></span>
      </div>

      <!-- Terminal body -->
      <div class="terminal-body">
        <!-- Loading state (shown until user scrolls here) -->
        <div class="terminal-loading" id="terminalLoading">
          <div class="loading-spinner" aria-hidden="true"></div>
          <p class="loading-text">AWAITING CONNECTION<span class="loading-dots">...</span></p>
        </div>

        <!-- Crash overlay (triggered by corrupted file) -->
        <div class="crash-overlay hidden" id="crashOverlay">
          <div class="crash-content">
            <p class="crash-header">☠ FATAL EXCEPTION ☠</p>
            <p class="crash-code">ERROR 0x00000404 — FILE_NOT_FOUND_BUT_ALSO_CURSED</p>
            <div class="crash-body">
              <p>> Attempted to open: AI_Agriculture.exe</p>
              <p>> File integrity check: <span class="crash-red">FAILED</span></p>
              <p>> Reason: This project doesn't exist yet lol</p>
              <p>> Vibes: <span class="crash-red">SUSPICIOUS</span></p>
              <p>&nbsp;</p>
              <p>> Recovering system...</p>
              <p>> Quarantining file...</p>
              <p class="crash-blink">DO NOT CLICK SUSPICIOUS FILES ▌</p>
            </div>
            <div class="crash-progress">
              <div class="crash-progress-bar" id="crashProgressBar"></div>
            </div>
            <p class="crash-status" id="crashStatus">REBOOTING IN 3...</p>
          </div>
        </div>

        <!-- Boot sequence area (typed in by JS) -->
        <div class="terminal-boot hidden" id="terminalBoot"></div>

        <!-- Main content (hidden until boot completes) -->
        <div class="terminal-main hidden" id="terminalMain">
          <!-- Breadcrumb path -->
          <div class="terminal-path" id="terminalPath">
            <span class="path-segment path-root" data-nav="root">~/projects</span>
          </div>

          <!-- Root directory listing -->
          <div class="fs-view" id="viewRoot">
          <div class="terminal-output">
            <p class="cmd-line"><span class="prompt-green">sdyer@creative-lab</span>:<span class="prompt-cyan">~/projects</span>$ ls -la</p>
            <p class="cmd-output">total 3 entries</p>
            <p class="cmd-output dim">drwxr-xr-x  4 sdyer  staff  128 Mar 24 09:41 .</p>
            <p class="cmd-output dim">drwxr-xr-x  8 sdyer  staff  256 Mar 24 09:41 ..</p>
          </div>

          <div class="fs-listing">
            <button class="fs-item fs-folder" data-target="subSpatial">
              <span class="fs-icon">📁</span>
              <span class="fs-name">Sub_Spatial_Studio/</span>
              <span class="fs-meta">drwxr-xr-x · 2.4GB · ACTIVE</span>
              <span class="fs-arrow">→</span>
            </button>
            <button class="fs-item fs-folder" data-target="autoCar">
              <span class="fs-icon">📁</span>
              <span class="fs-name">AutoCar_VR/</span>
              <span class="fs-meta">drwxr-xr-x · 1.8GB · IN_DEV</span>
              <span class="fs-arrow">→</span>
            </button>
            <button class="fs-item fs-corrupted" id="corruptedFile">
              <span class="fs-icon">⚠️</span>
              <span class="fs-name corrupted-name">AI_Agriculture<span class="corrupted-ext">.̷e̶x̸e̵</span></span>
              <span class="fs-meta corrupted-meta">-r?x--x--- · ?.??GB · UNKNOWN</span>
              <span class="fs-arrow corrupted-arrow">⌁</span>
            </button>
          </div>

          <div class="terminal-output">
            <p class="cmd-hint">Click a directory to explore ▸</p>
          </div>
        </div>

        <!-- Sub Spatial Studio view -->
        <div class="fs-view hidden" id="viewSubSpatial">
          <div class="terminal-output">
            <p class="cmd-line"><span class="prompt-green">sdyer@creative-lab</span>:<span class="prompt-cyan">~/projects/Sub_Spatial_Studio</span>$ cat README.md</p>
          </div>

          <div class="project-detail">
            <div class="detail-logo-wrap">
              <img src="/subspatialstudio.jpeg" alt="Sub Spatial Studio logo" class="detail-logo" />
            </div>
            <div class="detail-header">
              <div class="detail-title-row">
                <h3 class="detail-title">SUB SPATIAL STUDIO</h3>
                <span class="detail-status status--active">● ACTIVE</span>
              </div>
              <p class="detail-subtitle">Spatial Design Studio — visionOS / Apple Vision Pro</p>
            </div>

            <div class="detail-body">
              <div class="detail-section">
                <p class="detail-label">// OVERVIEW</p>
                <p class="detail-text">
                  An independent studio dedicated to designing and developing immersive applications for Apple Vision Pro. Sub Spatial Studio explores the frontier of spatial computing — crafting experiences that blend digital interfaces seamlessly into physical space.
                </p>
              </div>

              <div class="detail-section">
                <p class="detail-label">// FOCUS AREAS</p>
                <div class="detail-list">
                  <span class="detail-list-item">▹ visionOS Application Design</span>
                  <span class="detail-list-item">▹ Spatial UI/UX Prototyping</span>
                  <span class="detail-list-item">▹ RealityKit & SwiftUI Integration</span>
                  <span class="detail-list-item">▹ Immersive 3D Environments</span>
                </div>
              </div>

              <div class="detail-section">
                <p class="detail-label">// TECH STACK</p>
                <div class="detail-tags">
                  <span class="d-tag">visionOS</span>
                  <span class="d-tag">SwiftUI</span>
                  <span class="d-tag">RealityKit</span>
                  <span class="d-tag">Reality Composer Pro</span>
                  <span class="d-tag">ARKit</span>
                  <span class="d-tag">Spatial Computing</span>
                </div>
              </div>

              <div class="detail-actions">
                <a href="https://subspatial.studio" target="_blank" rel="noopener" class="detail-link detail-link--primary">
                  <span class="link-icon">◈</span> Visit Studio Website <span class="external-icon">↗</span>
                </a>
              </div>
            </div>

            <!-- File tree decoration -->
            <div class="detail-files">
              <p class="files-header">$ tree -L 1</p>
              <p class="file-entry">├── src/</p>
              <p class="file-entry">├── assets/</p>
              <p class="file-entry">├── prototypes/</p>
              <p class="file-entry">├── README.md</p>
              <p class="file-entry">└── package.json</p>
              <p class="file-count">3 directories, 2 files</p>
            </div>
          </div>
        </div>

        <!-- AutoCar VR view -->
        <div class="fs-view hidden" id="viewAutoCar">
          <div class="terminal-output">
            <p class="cmd-line"><span class="prompt-green">sdyer@creative-lab</span>:<span class="prompt-cyan">~/projects/AutoCar_VR</span>$ cat README.md</p>
          </div>

          <div class="project-detail">
            <div class="detail-header">
              <div class="detail-title-row">
                <h3 class="detail-title">AUTOCAR</h3>
                <span class="detail-status status--dev">◌ IN DEVELOPMENT</span>
              </div>
              <p class="detail-subtitle">Virtual Reality — DIY Car Repair System</p>
            </div>

            <div class="detail-body">
              <div class="detail-section">
                <p class="detail-label">// OVERVIEW</p>
                <p class="detail-text">
                  A VR application that places users inside a fully interactive virtual garage where they can learn hands-on car repair techniques. Step-by-step guided workflows walk users through real maintenance procedures — from brake pad replacements to engine diagnostics — using spatial hand tracking and 3D-annotated vehicle models.
                </p>
              </div>

              <div class="detail-section">
                <p class="detail-label">// KEY FEATURES</p>
                <div class="detail-list">
                  <span class="detail-list-item">▹ Interactive 3D vehicle models with exploded views</span>
                  <span class="detail-list-item">▹ Step-by-step guided repair workflows</span>
                  <span class="detail-list-item">▹ Hand-tracking tool interactions</span>
                  <span class="detail-list-item">▹ Real-time diagnostic overlay system</span>
                  <span class="detail-list-item">▹ Progress tracking & skill assessment</span>
                </div>
              </div>

              <div class="detail-section">
                <p class="detail-label">// TECH STACK</p>
                <div class="detail-tags">
                  <span class="d-tag">Unity</span>
                  <span class="d-tag">XR Interaction Toolkit</span>
                  <span class="d-tag">Blender</span>
                  <span class="d-tag">Hand Tracking</span>
                  <span class="d-tag">C#</span>
                  <span class="d-tag">Meta Quest</span>
                </div>
              </div>

              <div class="detail-actions">
                <span class="detail-link detail-link--disabled">
                  <span class="link-icon">◈</span> Coming Soon — In Development
                </span>
              </div>
            </div>

            <!-- File tree decoration -->
            <div class="detail-files">
              <p class="files-header">$ tree -L 1</p>
              <p class="file-entry">├── Assets/</p>
              <p class="file-entry">├── Scripts/</p>
              <p class="file-entry">├── Models/</p>
              <p class="file-entry">├── README.md</p>
              <p class="file-entry">└── ProjectSettings/</p>
              <p class="file-count">3 directories, 2 files</p>
            </div>
          </div>
        </div>

          <!-- Back button (shown inside project views) -->
          <button class="back-btn hidden" id="backBtn">
            <span class="back-arrow">←</span> cd ..
          </button>
        </div><!-- end .terminal-main -->
      </div>
    </div>
  </div>
</section>

<!-- File system navigation + scroll-triggered boot script -->
<script>
  document.addEventListener("DOMContentLoaded", () => {
    const CHAR_SPEED = 22;
    const LINE_PAUSE = 200;

    // Elements
    const section = document.getElementById("projects") as HTMLElement;
    const loadingEl = document.getElementById("terminalLoading") as HTMLElement;
    const bootEl = document.getElementById("terminalBoot") as HTMLElement;
    const mainEl = document.getElementById("terminalMain") as HTMLElement;
    const viewRoot = document.getElementById("viewRoot") as HTMLElement;
    const viewSubSpatial = document.getElementById("viewSubSpatial") as HTMLElement;
    const viewAutoCar = document.getElementById("viewAutoCar") as HTMLElement;
    const backBtn = document.getElementById("backBtn") as HTMLElement;
    const terminalTitle = document.getElementById("terminalTitle") as HTMLElement;
    const terminalPath = document.getElementById("terminalPath") as HTMLElement;

    let hasBooted = false;

    // ── Typewriter utility ──
    function typeText(el: HTMLElement, text: string, speed: number): Promise<void> {
      return new Promise((resolve) => {
        let i = 0;
        const cursor = document.createElement("span");
        cursor.className = "boot-cursor";
        cursor.textContent = "\u2588";
        el.appendChild(cursor);

        function tick() {
          if (i < text.length) {
            cursor.remove();
            el.insertAdjacentText("beforeend", text[i]);
            el.appendChild(cursor);
            i++;
            setTimeout(tick, speed);
          } else {
            cursor.remove();
            resolve();
          }
        }
        tick();
      });
    }

    function sleep(ms: number): Promise<void> {
      return new Promise((r) => setTimeout(r, ms));
    }

    // ── Boot sequence ──
    async function runBoot() {
      loadingEl.classList.add("hidden");
      bootEl.classList.remove("hidden");

      const lines = [
        { text: "sdyer@creative-lab:~$ cd projects", color: "green" },
        { text: "sdyer@creative-lab:~/projects$ ls -la", color: "green" },
        { text: "total 3 entries", color: "dim" },
        { text: "drwxr-xr-x  4 sdyer  staff  128 Mar 24 09:41 .", color: "dim" },
        { text: "drwxr-xr-x  8 sdyer  staff  256 Mar 24 09:41 ..", color: "dim" },
        { text: "drwxr-xr-x  6 sdyer  staff  2.4G  ACTIVE  Sub_Spatial_Studio/", color: "cyan" },
        { text: "drwxr-xr-x  5 sdyer  staff  1.8G  IN_DEV  AutoCar_VR/", color: "cyan" },
        { text: "-r?x--x---  ? sdyer  staff  ?.??G  ??????  AI_Agriculture.exe", color: "red" },
      ];

      for (const line of lines) {
        const p = document.createElement("p");
        p.className = `boot-line boot-line--${line.color}`;
        bootEl.appendChild(p);
        await typeText(p, line.text, CHAR_SPEED);
        await sleep(LINE_PAUSE);
      }

      await sleep(400);

      // Transition: fade boot out, show main content
      bootEl.style.transition = "opacity 0.4s ease";
      bootEl.style.opacity = "0";
      await sleep(400);
      bootEl.classList.add("hidden");
      mainEl.classList.remove("hidden");
      mainEl.style.animation = "fadeSlideIn 0.4s ease forwards";
    }

    // ── IntersectionObserver: trigger boot on scroll ──
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && !hasBooted) {
            hasBooted = true;
            observer.disconnect();
            runBoot();
          }
        });
      },
      { threshold: 0.15 }
    );

    observer.observe(section);

    // ── File system navigation ──
    const views: Record<string, HTMLElement> = {
      root: viewRoot,
      subSpatial: viewSubSpatial,
      autoCar: viewAutoCar,
    };

    const titles: Record<string, string> = {
      root: "sdyer@creative-lab:~/projects",
      subSpatial: "sdyer@creative-lab:~/projects/Sub_Spatial_Studio",
      autoCar: "sdyer@creative-lab:~/projects/AutoCar_VR",
    };

    const pathLabels: Record<string, string> = {
      subSpatial: "Sub_Spatial_Studio",
      autoCar: "AutoCar_VR",
    };

    function showView(key: string) {
      Object.values(views).forEach((v) => v.classList.add("hidden"));
      views[key].classList.remove("hidden");
      views[key].style.animation = "fadeSlideIn 0.35s ease forwards";
      terminalTitle.textContent = titles[key];

      if (key === "root") {
        terminalPath.innerHTML = `<span class="path-segment path-root" data-nav="root">~/projects</span>`;
        backBtn.classList.add("hidden");
      } else {
        terminalPath.innerHTML = `
          <span class="path-segment path-root" data-nav="root">~/projects</span>
          <span class="path-sep">/</span>
          <span class="path-segment path-current">${pathLabels[key]}</span>
        `;
        backBtn.classList.remove("hidden");
      }

      const rootEl = terminalPath.querySelector('[data-nav="root"]');
      if (rootEl) {
        rootEl.addEventListener("click", () => showView("root"));
      }
    }

    document.querySelectorAll(".fs-folder").forEach((btn) => {
      btn.addEventListener("click", () => {
        const target = (btn as HTMLElement).dataset.target;
        if (target) showView(target);
      });
    });

    backBtn.addEventListener("click", () => showView("root"));

    // ── Corrupted file crash sequence ──
    const corruptedFile = document.getElementById("corruptedFile") as HTMLButtonElement;
    const crashOverlay = document.getElementById("crashOverlay") as HTMLElement;
    const crashProgressBar = document.getElementById("crashProgressBar") as HTMLElement;
    const crashStatus = document.getElementById("crashStatus") as HTMLElement;
    const terminalWindow = document.querySelector(".terminal-window") as HTMLElement;

    let hasCrashed = false;

    corruptedFile.addEventListener("click", async () => {
      if (hasCrashed) return;
      hasCrashed = true;

      // Glitch the terminal
      terminalWindow.classList.add("glitching");
      await sleep(300);

      // Hide main content, show crash screen
      mainEl.classList.add("hidden");
      crashOverlay.classList.remove("hidden");
      terminalWindow.classList.remove("glitching");
      terminalWindow.classList.add("crash-mode");
      terminalTitle.textContent = "⚠ SYSTEM ERROR — PROCESS KILLED (SIGFAULT)";

      // Animate progress bar and countdown
      crashProgressBar.style.transition = "width 3s linear";
      requestAnimationFrame(() => {
        crashProgressBar.style.width = "100%";
      });

      await sleep(1000);
      crashStatus.textContent = "REBOOTING IN 2...";
      await sleep(1000);
      crashStatus.textContent = "REBOOTING IN 1...";
      await sleep(1000);
      crashStatus.textContent = "RESTORING SESSION...";
      await sleep(500);

      // Recover
      terminalWindow.classList.remove("crash-mode");
      crashOverlay.classList.add("hidden");
      mainEl.classList.remove("hidden");
      mainEl.style.animation = "fadeSlideIn 0.4s ease forwards";
      terminalTitle.textContent = titles["root"];
      showView("root");

      // Mark corrupted file as broken
      corruptedFile.classList.add("fs-corrupted--broken");
      corruptedFile.disabled = true;
      const nameEl = corruptedFile.querySelector(".corrupted-name") as HTMLElement;
      if (nameEl) nameEl.innerHTML = 'AI_Agriculture<span class="corrupted-ext">.̷e̶x̸e̵</span> <span class="broken-tag">[QUARANTINED]</span>';
      const metaEl = corruptedFile.querySelector(".corrupted-meta") as HTMLElement;
      if (metaEl) metaEl.textContent = "FILE QUARANTINED · ACCESS DENIED";
      const arrowEl = corruptedFile.querySelector(".corrupted-arrow") as HTMLElement;
      if (arrowEl) arrowEl.textContent = "✕";
    });
  });
</script>

<style>
  .accent-green {
    color: var(--col-neon-green);
    text-shadow: 0 0 20px rgba(0, 255, 65, 0.25);
  }

  .proj-intro {
    max-width: 640px;
    margin-bottom: 48px;
    font-size: 1.05rem;
  }

  /* ── Terminal Window ── */
  .terminal-window {
    border: 1px solid var(--col-border);
    background: #0c0c10;
    overflow: hidden;
    max-width: 900px;
  }

  /* Title bar */
  .terminal-titlebar {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 16px;
    background: #18181f;
    border-bottom: 1px solid var(--col-border);
  }

  .titlebar-dots {
    display: flex;
    gap: 6px;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .dot--red { background: #ff5f57; }
  .dot--yellow { background: #ffbd2e; }
  .dot--green { background: #28c840; }

  .titlebar-text {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--col-text-dim);
    letter-spacing: 0.1em;
    flex: 1;
    text-align: center;
  }

  .titlebar-spacer {
    width: 44px;
  }

  /* Terminal body */
  .terminal-body {
    padding: 24px;
    min-height: 400px;
    position: relative;
  }

  /* Breadcrumb path */
  .terminal-path {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    margin-bottom: 20px;
    padding-bottom: 12px;
    border-bottom: 1px solid rgba(42,42,53,0.5);
    display: flex;
    align-items: center;
    gap: 0;
  }

  .path-segment {
    color: var(--col-neon-cyan);
  }

  .path-root {
    cursor: pointer;
    transition: color 0.2s;
  }

  .path-root:hover {
    color: var(--col-neon-green);
    text-shadow: 0 0 8px rgba(0,255,65,0.3);
  }

  .path-sep {
    color: var(--col-text-dim);
    margin: 0 2px;
  }

  .path-current {
    color: var(--col-heading);
  }

  /* Terminal output text */
  .terminal-output {
    margin-bottom: 16px;
  }

  .cmd-line {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--col-text);
    letter-spacing: 0.08em;
    margin-bottom: 4px;
  }

  .prompt-green { color: var(--col-neon-green); }
  .prompt-cyan { color: var(--col-neon-cyan); }

  .cmd-output {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--col-text);
    letter-spacing: 0.08em;
    line-height: 1.8;
  }

  .cmd-output.dim {
    color: var(--col-text-dim);
    opacity: 0.5;
  }

  .cmd-hint {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--col-text-dim);
    letter-spacing: 0.15em;
    margin-top: 8px;
    animation: pulse-hint 2s ease infinite;
  }

  @keyframes pulse-hint {
    0%, 100% { opacity: 0.5; }
    50% { opacity: 1; }
  }

  /* ── File system listing ── */
  .fs-listing {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-bottom: 12px;
  }

  .fs-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    background: rgba(17,17,22,0.6);
    border: 1px solid var(--col-border);
    cursor: pointer;
    transition: all 0.25s ease;
    text-align: left;
    width: 100%;
    font-family: inherit;
    color: inherit;
  }

  .fs-item:hover {
    background: rgba(0,255,65,0.04);
    border-color: rgba(0,255,65,0.25);
    transform: translateX(4px);
  }

  .fs-icon {
    font-size: 1.2rem;
    flex-shrink: 0;
  }

  .fs-name {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--col-neon-cyan);
    letter-spacing: 0.08em;
    font-weight: 500;
    flex: 1;
  }

  .fs-item:hover .fs-name {
    color: var(--col-neon-green);
    text-shadow: 0 0 8px rgba(0,255,65,0.3);
  }

  .fs-meta {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    color: var(--col-text-dim);
    letter-spacing: 0.12em;
  }

  .fs-arrow {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--col-text-dim);
    transition: transform 0.2s, color 0.2s;
  }

  .fs-item:hover .fs-arrow {
    transform: translateX(4px);
    color: var(--col-neon-green);
  }

  /* ── Project detail view ── */
  .project-detail {
    border: 1px solid var(--col-border);
    background: var(--col-surface);
    overflow: hidden;
  }

  .detail-logo-wrap {
    padding: 28px 28px 0;
    display: flex;
    justify-content: center;
    background: rgba(0,0,0,0.3);
    border-bottom: 1px solid var(--col-border);
  }

  .detail-logo {
    max-width: 280px;
    width: 100%;
    height: auto;
    object-fit: contain;
    border-radius: 4px;
    opacity: 0.9;
    transition: opacity 0.3s ease;
  }

  .detail-logo:hover {
    opacity: 1;
  }

  .detail-header {
    padding: 24px 28px;
    border-bottom: 1px solid var(--col-border);
    background: rgba(0,255,65,0.02);
  }

  .detail-title-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 6px;
    flex-wrap: wrap;
    gap: 12px;
