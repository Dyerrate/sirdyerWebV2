---
---

<div class="ascii-stage" id="asciiHeadStage" aria-hidden="true">
  <div class="ascii-glow" id="asciiHeadGlow"></div>
  <div class="ascii-output" id="asciiHeadOutput"></div>
</div>

<script>
  import * as THREE from "three";
  import { AsciiEffect } from "three/examples/jsm/effects/AsciiEffect.js";

  document.addEventListener("DOMContentLoaded", () => {
    const stage = document.getElementById("asciiHeadStage") as HTMLElement | null;
    const output = document.getElementById("asciiHeadOutput") as HTMLElement | null;
    const glowEl = document.getElementById("asciiHeadGlow") as HTMLElement | null;
    if (!stage || !output || !glowEl) return;

    let scene: THREE.Scene | null = null;
    let camera: THREE.PerspectiveCamera | null = null;
    let renderer: THREE.WebGLRenderer | null = null;
    let effect: AsciiEffect | null = null;
    let headGroup: THREE.Group | null = null;
    let eyeLPivot: THREE.Group | null = null;
    let eyeRPivot: THREE.Group | null = null;
    let upperLipMesh: THREE.Mesh | null = null;
    let lowerLipMesh: THREE.Mesh | null = null;
    let mouthCavityMesh: THREE.Mesh | null = null;
    // Baseline mouth positions (captured from buildHead so tick() can offset them)
    const UPPER_LIP_Y = -0.5;
    const LOWER_LIP_Y = -0.62;
    const CAVITY_Y = -0.56;

    let running = false;
    let rafId: number | null = null;
    let initialized = false;

    // Cursor state
    let mouseNX = 0;
    let mouseNY = 0;
    let mouseRawX = 0;
    let mouseRawY = 0;
    let glowX = 0;
    let glowY = 0;
    let glowInit = false;

    const HEAD_LERP = 0.025;
    const EYE_LERP = 0.08;
    const GLOW_LERP = 0.009;

    function buildHead(): {
      group: THREE.Group;
      eyeL: THREE.Group;
      eyeR: THREE.Group;
      upperLip: THREE.Mesh;
      lowerLip: THREE.Mesh;
      mouthCavity: THREE.Mesh;
    } {
      const group = new THREE.Group();
      const skinMat = new THREE.MeshPhongMaterial({
        color: 0xffffff,
        shininess: 18,
        flatShading: false,
      });
      const eyeWhiteMat = new THREE.MeshPhongMaterial({
        color: 0xffffff,
        shininess: 60,
      });
      const pupilMat = new THREE.MeshPhongMaterial({
        color: 0x111111,
        shininess: 5,
      });
      const mouthMat = new THREE.MeshPhongMaterial({
        color: 0x040404,
        shininess: 1,
      });

      // Skull
      const skull = new THREE.Mesh(
        new THREE.SphereGeometry(1, 48, 48),
        skinMat,
      );
      skull.scale.set(1, 1.15, 1);
      group.add(skull);

      // Jaw / chin
      const jaw = new THREE.Mesh(
        new THREE.SphereGeometry(0.78, 36, 36),
        skinMat,
      );
      jaw.scale.set(0.9, 0.7, 0.9);
      jaw.position.set(0, -0.7, 0.05);
      group.add(jaw);

      // Brow ridge
      const brow = new THREE.Mesh(
        new THREE.BoxGeometry(1.05, 0.12, 0.32),
        skinMat,
      );
      brow.position.set(0, 0.28, 0.78);
      group.add(brow);

      // Nose
      const nose = new THREE.Mesh(
        new THREE.ConeGeometry(0.12, 0.42, 16),
        skinMat,
      );
      nose.rotation.x = Math.PI / 2;
      nose.position.set(0, -0.05, 1.02);
      group.add(nose);
      const nostrils = new THREE.Mesh(
        new THREE.SphereGeometry(0.13, 16, 16),
        skinMat,
      );
      nostrils.scale.set(1.2, 0.6, 0.7);
      nostrils.position.set(0, -0.22, 1.0);
      group.add(nostrils);

      // Cheekbones (subtle)
      for (const sx of [-1, 1]) {
        const cheek = new THREE.Mesh(
          new THREE.SphereGeometry(0.32, 24, 24),
          skinMat,
        );
        cheek.position.set(sx * 0.5, -0.18, 0.78);
        cheek.scale.set(1, 0.7, 0.6);
        group.add(cheek);
      }

      // Mouth — split into upper/lower lip with a dark cavity between so it
      // can open and close. Y positions are baselines; tick() animates them.
      const upperLip = new THREE.Mesh(
        new THREE.SphereGeometry(0.22, 24, 24),
        skinMat,
      );
      upperLip.scale.set(1.4, 0.16, 0.6);
      upperLip.position.set(0, -0.5, 0.92);
      group.add(upperLip);

      const lowerLip = new THREE.Mesh(
        new THREE.SphereGeometry(0.22, 24, 24),
        skinMat,
      );
      lowerLip.scale.set(1.3, 0.18, 0.58);
      lowerLip.position.set(0, -0.62, 0.91);
      group.add(lowerLip);

      const mouthCavity = new THREE.Mesh(
        new THREE.SphereGeometry(0.2, 20, 20),
        mouthMat,
      );
      mouthCavity.scale.set(1.15, 0.06, 0.5);
      mouthCavity.position.set(0, -0.56, 0.84);
      group.add(mouthCavity);

      // Ears
      for (const sx of [-1, 1]) {
        const ear = new THREE.Mesh(
          new THREE.SphereGeometry(0.18, 20, 20),
          skinMat,
        );
        ear.scale.set(0.4, 1, 0.7);
        ear.position.set(sx * 1.0, -0.05, 0);
        group.add(ear);
      }

      // Hair cap (a slightly larger sphere chunk on top)
      const hair = new THREE.Mesh(
        new THREE.SphereGeometry(1.04, 36, 36, 0, Math.PI * 2, 0, Math.PI * 0.55),
        skinMat,
      );
      hair.scale.set(1, 1.15, 1);
      hair.position.set(0, 0.05, 0);
      group.add(hair);

      // Eye pivots (so eyes can rotate independently)
      const eyeL = new THREE.Group();
      const eyeR = new THREE.Group();
      eyeL.position.set(-0.34, 0.12, 0.82);
      eyeR.position.set(0.34, 0.12, 0.82);

      const eyeballGeo = new THREE.SphereGeometry(0.16, 24, 24);
      const eyeballL = new THREE.Mesh(eyeballGeo, eyeWhiteMat);
      const eyeballR = new THREE.Mesh(eyeballGeo, eyeWhiteMat);
      eyeL.add(eyeballL);
      eyeR.add(eyeballR);

      // Pupils — placed forward of the eyeball so rotation of the pivot
      // sweeps them across the visible face like a gaze.
      const pupilGeo = new THREE.SphereGeometry(0.07, 16, 16);
      const pupilL = new THREE.Mesh(pupilGeo, pupilMat);
      const pupilR = new THREE.Mesh(pupilGeo, pupilMat);
      pupilL.position.set(0, 0, 0.12);
      pupilR.position.set(0, 0, 0.12);
      eyeL.add(pupilL);
      eyeR.add(pupilR);

      group.add(eyeL);
      group.add(eyeR);

      // Neck
      const neck = new THREE.Mesh(
        new THREE.CylinderGeometry(0.45, 0.55, 0.7, 24),
        skinMat,
      );
      neck.position.set(0, -1.35, -0.05);
      group.add(neck);

      // Shoulder hint (top of torso, just to anchor the neck visually)
      const shoulders = new THREE.Mesh(
        new THREE.SphereGeometry(0.9, 24, 24),
        skinMat,
      );
      shoulders.scale.set(1.6, 0.45, 0.9);
      shoulders.position.set(0, -1.85, -0.1);
      group.add(shoulders);

      return { group, eyeL, eyeR, upperLip, lowerLip, mouthCavity };
    }

    function getStageSize() {
      const r = stage!.getBoundingClientRect();
      return {
        w: Math.max(1, Math.floor(r.width)),
        h: Math.max(1, Math.floor(r.height)),
      };
    }

    function init() {
      if (initialized) return;
      const { w, h } = getStageSize();
      if (w === 0 || h === 0) return;

      scene = new THREE.Scene();
      scene.background = null;

      camera = new THREE.PerspectiveCamera(38, w / h, 0.1, 100);
      camera.position.set(0, 0.1, 3.9);
      camera.lookAt(0, -0.1, 0);

      // Lights
      const ambient = new THREE.AmbientLight(0xffffff, 0.35);
      scene.add(ambient);
      const key = new THREE.DirectionalLight(0xffffff, 1.1);
      key.position.set(-2.5, 3, 4);
      scene.add(key);
      const rim = new THREE.DirectionalLight(0xffffff, 0.35);
      rim.position.set(3, 1.5, -2);
      scene.add(rim);

      // Head
      const built = buildHead();
      headGroup = built.group;
      eyeLPivot = built.eyeL;
      eyeRPivot = built.eyeR;
      upperLipMesh = built.upperLip;
      lowerLipMesh = built.lowerLip;
      mouthCavityMesh = built.mouthCavity;
      scene.add(headGroup);

      // Renderer + ASCII effect
      renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
      renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 2));
      renderer.setSize(w, h);
      renderer.setClearColor(0x000000, 0);

      effect = new AsciiEffect(renderer, " .:-+*=%@#", { invert: true });
      effect.setSize(w, h);
      const eDom = effect.domElement as HTMLElement;
      eDom.style.color = "var(--col-neon-red)";
      eDom.style.backgroundColor = "transparent";
      eDom.style.position = "absolute";
      eDom.style.inset = "0";
      eDom.style.display = "flex";
      eDom.style.alignItems = "center";
      eDom.style.justifyContent = "center";
      output!.appendChild(eDom);

      // Initialize the spotlight mask off-stage so head starts hidden
      output!.style.setProperty("--mask-x", `-9999px`);
      output!.style.setProperty("--mask-y", `-9999px`);

      initialized = true;
    }

    function resize() {
      if (!initialized || !renderer || !effect || !camera) return;
      const { w, h } = getStageSize();
      if (w === 0 || h === 0) return;
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
      renderer.setSize(w, h);
      effect.setSize(w, h);
    }

    function tick() {
      if (!running || !effect || !scene || !camera) return;

      if (headGroup) {
        const yawTarget = mouseNX * 0.55;
        const pitchTarget = -mouseNY * 0.3;
        headGroup.rotation.y += (yawTarget - headGroup.rotation.y) * HEAD_LERP;
        headGroup.rotation.x += (pitchTarget - headGroup.rotation.x) * HEAD_LERP;
      }

      const eyeYawTarget = mouseNX * 0.6;
      const eyePitchTarget = -mouseNY * 0.4;
      for (const pivot of [eyeLPivot, eyeRPivot]) {
        if (!pivot) continue;
        pivot.rotation.y += (eyeYawTarget - pivot.rotation.y) * EYE_LERP;
        pivot.rotation.x += (eyePitchTarget - pivot.rotation.x) * EYE_LERP;
      }

      // Mouth animation — layered sine waves give a quiet "muttering"
      // baseline with occasional wider opens, like the head is whispering.
      const tSec = performance.now() * 0.001;
      const breathe = Math.sin(tSec * 1.7) * 0.5 + 0.5;          // 0..1, slow
      const chatter = Math.sin(tSec * 6.3) * 0.5 + 0.5;          // 0..1, fast
      const burst = Math.max(0, Math.sin(tSec * 0.45) - 0.25);   // 0..0.75, sparse
      const open = Math.min(
        1,
        breathe * 0.25 + chatter * burst * 1.6,
      );
      if (upperLipMesh) upperLipMesh.position.y = UPPER_LIP_Y + open * 0.04;
      if (lowerLipMesh) lowerLipMesh.position.y = LOWER_LIP_Y - open * 0.18;
      if (mouthCavityMesh) {
        mouthCavityMesh.scale.y = 0.06 + open * 1.4;
        mouthCavityMesh.position.y = CAVITY_Y - open * 0.07;
      }

      if (glowInit) {
        glowX += (mouseRawX - glowX) * GLOW_LERP;
        glowY += (mouseRawY - glowY) * GLOW_LERP;

        // Proximity: 1 when the spotlight has caught up to the cursor, 0 when
        // it's still well behind. Drives size + brightness so the light
        // pulses up as it reaches the mouse and dims/shrinks while chasing.
        const dx = mouseRawX - glowX;
        const dy = mouseRawY - glowY;
        const dist = Math.sqrt(dx * dx + dy * dy);
        const MAX_CHASE = 420;
        const proximity = Math.max(0, 1 - dist / MAX_CHASE);
        const eased = proximity * proximity * (3 - 2 * proximity);

        const SPOT_R_MIN = 40;
        const SPOT_R_MAX = 320;
        const GLOW_SCALE_MIN = 0.22;
        const GLOW_SCALE_MAX = 1;
        const GLOW_OPACITY_MIN = 0.1;
        const GLOW_OPACITY_MAX = 0.65;

        const spotR =
          SPOT_R_MIN + (SPOT_R_MAX - SPOT_R_MIN) * eased;
        const glowScale =
          GLOW_SCALE_MIN + (GLOW_SCALE_MAX - GLOW_SCALE_MIN) * eased;
        const glowOpacity =
          GLOW_OPACITY_MIN + (GLOW_OPACITY_MAX - GLOW_OPACITY_MIN) * eased;

        glowEl!.style.transform = `translate(-50%, -50%) translate3d(${glowX}px, ${glowY}px, 0) scale(${glowScale})`;
        glowEl!.style.opacity = `${glowOpacity}`;
        // The spotlight that "reveals" the head sits on the lagging light
        output!.style.setProperty("--mask-x", `${glowX}px`);
        output!.style.setProperty("--mask-y", `${glowY}px`);
        output!.style.setProperty("--mask-r", `${spotR}px`);
      }

      effect.render(scene, camera);
      rafId = requestAnimationFrame(tick);
    }

    function start() {
      if (running) return;
      init();
      if (!initialized) return;
      running = true;
      rafId = requestAnimationFrame(tick);
    }

    function stop() {
      running = false;
      if (rafId !== null) {
        cancelAnimationFrame(rafId);
        rafId = null;
      }
    }

    // Cursor wiring — track globally across the whole window so the head
    // is "constantly tracking" even when the cursor is far from the stage.
    // Head rotation is normalized against the viewport; mask + glow positions
    // are kept in stage-local coords so the spotlight reveal aligns with
    // the rendered ASCII grid.
    window.addEventListener("pointermove", (e) => {
      mouseNX = (e.clientX / window.innerWidth) * 2 - 1;
      mouseNY = -((e.clientY / window.innerHeight) * 2 - 1);
      const r = stage.getBoundingClientRect();
      mouseRawX = e.clientX - r.left;
      mouseRawY = e.clientY - r.top;
      if (!glowInit) {
        glowX = mouseRawX;
        glowY = mouseRawY;
        glowInit = true;
      }
    });

    // Resize
    const ro = new ResizeObserver(() => resize());
    ro.observe(stage);
    window.addEventListener("resize", resize);

    // Pause when the tab is hidden (RAF naturally pauses too, but this stops
    // the loop variable from growing arbitrarily on resume).
    document.addEventListener("visibilitychange", () => {
      if (document.hidden) stop();
      else start();
    });

    // Run continuously — head is now a global background, not a section.
    start();
  });
</script>

<style>
  .ascii-stage {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
    background:
      radial-gradient(ellipse at 50% 35%, #0a0205 0%, #030001 70%),
      #020001;
  }

  .ascii-glow {
    position: absolute;
    left: 0;
    top: 0;
    width: 360px;
    height: 360px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(255, 32, 64, 0.42) 0%,
      rgba(255, 32, 64, 0.12) 38%,
      transparent 68%
    );
    filter: blur(55px);
    pointer-events: none;
    transform: translate(-50%, -50%) translate3d(50%, 50%, 0);
    will-change: transform;
    z-index: 0;
    mix-blend-mode: screen;
  }

  .ascii-output {
    --mask-x: -9999px;
    --mask-y: -9999px;
    --mask-r: 80px;
    position: absolute;
    inset: 0;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    color: var(--col-neon-red);
    text-shadow: 0 0 8px var(--col-glow-red);
    line-height: 1;
    letter-spacing: 0;
    pointer-events: none;
    /* Spotlight reveal — radius and brightness are driven by JS based on how
       close the lagging light is to the cursor. While it's still chasing, the
       spotlight stays small and dim; it blooms to full size when it catches up. */
    -webkit-mask-image: radial-gradient(
      circle var(--mask-r) at var(--mask-x) var(--mask-y),
      rgba(0, 0, 0, 0.85) 18%,
      rgba(0, 0, 0, 0.4) 50%,
      transparent 68%
    );
    mask-image: radial-gradient(
      circle var(--mask-r) at var(--mask-x) var(--mask-y),
      rgba(0, 0, 0, 0.85) 18%,
      rgba(0, 0, 0, 0.4) 50%,
      transparent 68%
    );
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
  }

  /* AsciiEffect injects a <table> — keep monospace tight */
  .ascii-output :global(table) {
    border-collapse: collapse;
    border-spacing: 0;
  }
  .ascii-output :global(td) {
    padding: 0;
    line-height: 1;
  }

  @media (max-width: 768px) {
    .ascii-glow { width: 240px; height: 240px; }
  }
</style>
