---
---

<section id="hero" class="hero">
  <!-- Full-bleed looping video background -->
  <div class="hero-video-wrap" aria-hidden="true">
    <video autoplay muted loop playsinline class="hero-video" id="heroVideo">
      <source src="/backgroundLoop.mp4" type="video/mp4" />
    </video>
    <div class="hero-video-overlay" id="heroOverlay"></div>
  </div>

  <!-- Animated grid background -->
  <div class="hero-grid" aria-hidden="true"></div>

  <!-- Horizontal HUD lines -->
  <div class="hud-line hud-line--top" aria-hidden="true"></div>
  <div class="hud-line hud-line--bottom" aria-hidden="true"></div>

  <!-- Corner brackets -->
  <div class="corner corner--tl" aria-hidden="true"></div>
  <div class="corner corner--tr" aria-hidden="true"></div>
  <div class="corner corner--bl" aria-hidden="true"></div>
  <div class="corner corner--br" aria-hidden="true"></div>

  <!-- Side data readout -->
  <div class="side-readout" aria-hidden="true" id="sideReadout">
    <span>SYS.LOAD: 98.2%</span>
    <span>MEM: 16384 MB</span>
    <span>UPTIME: 4y.11mo</span>
    <span>NODE: ACTIVE</span>
  </div>

  <div class="hero-content" id="heroContent">
    <!-- Boot-sequence lines — typed in by JS -->
    <div class="boot-sequence" id="bootSequence">
      <p class="boot-line" id="boot1"></p>
      <p class="boot-line boot-line--dim" id="boot2"></p>
      <p class="boot-line boot-line--dim" id="boot3"></p>
    </div>

    <h1 class="hero-name" id="heroName">
      <span id="nameLine1"></span>
      <span class="hero-name-accent" id="nameLine2"></span>
    </h1>

    <p class="hero-tagline" id="heroTagline"></p>

    <div class="hero-tags" id="heroTags">
      <span class="tag">AR / VR</span>
      <span class="tag">Spatial Computing</span>
      <span class="tag">Creative Code</span>
      <span class="tag">Full-Stack</span>
      <span class="tag">React</span>
    </div>

    <div class="hero-cta" id="heroCta">
      <a href="#experience" class="cta-primary">
        <span class="cta-icon">◈</span> View Dossier
      </a>
      <a href="#vision" class="cta-secondary">Explore Vision →</a>
      <a href="#contact" class="cta-tertiary">Establish Link</a>
    </div>
  </div>

  <!-- Scrolling data strip -->
  <div class="data-strip" aria-hidden="true" id="dataStrip">
    <div class="data-strip-inner">
      PORTFOLIO: SAMUEL_DYER — SECTOR: CREATIVE_TECH — CLEARANCE: PUBLIC — DISCIPLINE: SOFTWARE_ENGINEERING — FOCUS: AR/VR — STACK: REACT / NODE / AWS — SIGNAL: STRONG — PROTOCOL: SPATIAL_v3 —&nbsp;
      PORTFOLIO: SAMUEL_DYER — SECTOR: CREATIVE_TECH — CLEARANCE: PUBLIC — DISCIPLINE: SOFTWARE_ENGINEERING — FOCUS: AR/VR — STACK: REACT / NODE / AWS — SIGNAL: STRONG — PROTOCOL: SPATIAL_v3 —&nbsp;
    </div>
  </div>
</section>

<!-- Client-side typewriter & video fade script -->
<script>
  document.addEventListener("DOMContentLoaded", () => {
    const CHAR_SPEED = 28;
    const LINE_PAUSE = 250;
    const INITIAL_DELAY = 2000;
    const VIDEO_FADE_DURATION = 2500;

    // Elements
    const video = document.getElementById("heroVideo") as HTMLVideoElement;
    const overlay = document.getElementById("heroOverlay") as HTMLElement;
    const boot1 = document.getElementById("boot1") as HTMLElement;
    const boot2 = document.getElementById("boot2") as HTMLElement;
    const boot3 = document.getElementById("boot3") as HTMLElement;
    const nameLine1 = document.getElementById("nameLine1") as HTMLElement;
    const nameLine2 = document.getElementById("nameLine2") as HTMLElement;
    const heroTagline = document.getElementById("heroTagline") as HTMLElement;
    const heroTags = document.getElementById("heroTags") as HTMLElement;
    const heroCta = document.getElementById("heroCta") as HTMLElement;
    const dataStrip = document.getElementById("dataStrip") as HTMLElement;
    const sideReadout = document.getElementById("sideReadout") as HTMLElement;
    const bootSequence = document.getElementById("bootSequence") as HTMLElement;

    // Hide content initially
    bootSequence.style.opacity = "0";
    heroTags.style.opacity = "0";
    heroCta.style.opacity = "0";
    dataStrip.style.opacity = "0";
    sideReadout.style.opacity = "0";

    // Reusable blinking cursor
    const cursor = document.createElement("span");
    cursor.className = "blink";
    cursor.textContent = "\u2588";

    function typeText(el: HTMLElement, text: string, speed: number): Promise<void> {
      return new Promise((resolve) => {
        let i = 0;
        el.appendChild(cursor);

        function tick() {
          if (i < text.length) {
            cursor.remove();
            el.insertAdjacentText("beforeend", text[i]);
            el.appendChild(cursor);
            i++;
            setTimeout(tick, speed);
          } else {
            cursor.remove();
            resolve();
          }
        }
        tick();
      });
    }

    function fadeIn(el: HTMLElement, duration = 400): Promise<void> {
      return new Promise((resolve) => {
        el.style.transition = `opacity ${duration}ms ease`;
        el.style.opacity = "1";
        setTimeout(resolve, duration);
      });
    }

    function sleep(ms: number): Promise<void> {
      return new Promise((r) => setTimeout(r, ms));
    }

    // Fade video from bright → dim
    function fadeVideoDown() {
      video.style.transition = `opacity ${VIDEO_FADE_DURATION}ms ease, filter ${VIDEO_FADE_DURATION}ms ease`;
      video.style.opacity = "0.25";
      video.style.filter = "saturate(0.3) contrast(1.2) brightness(0.6)";

      overlay.style.transition = `opacity ${VIDEO_FADE_DURATION}ms ease`;
      overlay.style.opacity = "1";
    }

    // Main intro sequence
    async function runIntro() {
      // Phase 1: user watches video for 2 seconds
      await sleep(INITIAL_DELAY);

      // Phase 2: fade video down, start typing
      fadeVideoDown();
      await fadeIn(bootSequence, 200);

      // Boot lines
      await typeText(boot1, "> INITIALIZING PORTFOLIO_OS v2.6", CHAR_SPEED);
      await sleep(LINE_PAUSE);
      await typeText(boot2, "> LOADING MODULES: AR_ENGINE / VR_CORE / CREATIVE_RUNTIME", CHAR_SPEED);
      await sleep(LINE_PAUSE);
      await typeText(boot3, "> STATUS: ", CHAR_SPEED);

      // Green status text
      const statusSpan = document.createElement("span");
      statusSpan.className = "status-green";
      boot3.appendChild(statusSpan);
      await typeText(statusSpan, "ALL SYSTEMS NOMINAL", CHAR_SPEED);
      await sleep(LINE_PAUSE * 2);

      // Name — typed larger
      await typeText(nameLine1, "Samuel", CHAR_SPEED * 2);
      nameLine1.insertAdjacentHTML("afterend", "<br/>");
      await sleep(150);
      await typeText(nameLine2, "Dyer", CHAR_SPEED * 2);
      await sleep(LINE_PAUSE);

      // Tagline
      await typeText(heroTagline, "Software Engineer  \u00b7  Creative Technologist", CHAR_SPEED);
      heroTagline.insertAdjacentHTML("beforeend", "<br/>");
      const cyanSpan = document.createElement("span");
      cyanSpan.className = "highlight-cyan";
      heroTagline.appendChild(cyanSpan);
      await typeText(cyanSpan, "Crafting immersive experiences at the boundary of code & spatial reality.", CHAR_SPEED);
      await sleep(LINE_PAUSE);

      // Fade in remaining elements
      await fadeIn(heroTags, 500);
      await sleep(100);
      await fadeIn(heroCta, 500);
      await fadeIn(dataStrip, 600);
      fadeIn(sideReadout, 800);

      // Final blinking cursor on last boot line
      boot3.appendChild(document.createTextNode(" "));
      const finalCursor = document.createElement("span");
      finalCursor.className = "blink";
      finalCursor.textContent = "\u2588";
      boot3.appendChild(finalCursor);
    }

    runIntro();
  });
</script>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    overflow: hidden;
    padding-top: 56px;
  }

  /* ── Video Background ── */
  .hero-video-wrap {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.85;
    filter: saturate(0.5) contrast(1.1) brightness(0.8);
  }

  .hero-video-overlay {
    position: absolute;
    inset: 0;
    opacity: 0;
    background:
      linear-gradient(180deg, rgba(10,10,12,0.85) 0%, rgba(10,10,12,0.4) 40%, rgba(10,10,12,0.7) 80%, rgba(10,10,12,1) 100%),
      linear-gradient(90deg, rgba(10,10,12,0.8) 0%, transparent 40%, transparent 60%, rgba(10,10,12,0.8) 100%);
  }

  /* ── Grid BG ── */
  .hero-grid {
    position: absolute;
    inset: 0;
    z-index: 1;
    background-image:
      linear-gradient(rgba(0, 255, 65, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 255, 65, 0.05) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse at center, black 20%, transparent 70%);
  }

  /* ── HUD Lines ── */
  .hud-line {
    position: absolute;
    left: 5%;
    right: 5%;
    height: 1px;
    z-index: 1;
  }

  .hud-line--top {
    top: 12%;
    background: linear-gradient(90deg, transparent, rgba(0,255,65,0.15) 30%, rgba(0,255,65,0.15) 70%, transparent);
  }

  .hud-line--bottom {
    bottom: 12%;
    background: linear-gradient(90deg, transparent, rgba(0,212,255,0.12) 30%, rgba(0,212,255,0.12) 70%, transparent);
  }

  /* ── Corner Brackets ── */
  .corner {
    position: absolute;
    width: 30px;
    height: 30px;
    z-index: 2;
    border-color: rgba(0,255,65,0.2);
    border-style: solid;
    border-width: 0;
  }

  .corner--tl { top: 24px; left: 24px; border-top-width: 2px; border-left-width: 2px; }
  .corner--tr { top: 24px; right: 24px; border-top-width: 2px; border-right-width: 2px; }
  .corner--bl { bottom: 48px; left: 24px; border-bottom-width: 2px; border-left-width: 2px; }
  .corner--br { bottom: 48px; right: 24px; border-bottom-width: 2px; border-right-width: 2px; }

  /* ── Side Readout ── */
  .side-readout {
    position: absolute;
    right: 28px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 0.55rem;
    color: var(--col-text-dim);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    opacity: 0;
    writing-mode: horizontal-tb;
    text-align: right;
  }

  /* ── Content ── */
  .hero-content {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
    position: relative;
    z-index: 3;
  }

  /* ── Boot Sequence ── */
  .boot-sequence {
    margin-bottom: 32px;
    border-left: 2px solid rgba(0,255,65,0.2);
    padding-left: 16px;
    min-height: 4.2em;
  }

  .boot-line {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--col-neon-green);
    letter-spacing: 0.15em;
    line-height: 2;
    min-height: 1.4em;
  }

  .boot-line--dim {
    color: var(--col-text-dim);
  }

  .prompt {
    color: var(--col-neon-green);
    margin-right: 4px;
  }

  .status-green {
    color: var(--col-neon-green);
  }

  .blink {
    animation: blink-cursor 1s step-end infinite;
  }

  @keyframes blink-cursor {
    50% { opacity: 0; }
  }

  /* ── Name ── */
  .hero-name {
    font-size: clamp(3.2rem, 10vw, 7.5rem);
    font-weight: 900;
    letter-spacing: 0.06em;
    line-height: 0.92;
    margin-bottom: 20px;
    color: var(--col-heading);
    text-shadow: 0 0 60px rgba(0,255,65,0.06);
    min-height: 1.85em;
  }

  .hero-name-accent {
    color: var(--col-neon-green);
    text-shadow:
      0 0 30px rgba(0, 255, 65, 0.35),
      0 0 80px rgba(0, 255, 65, 0.12);
  }

  .hero-tagline {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2.5vw, 1.3rem);
    font-weight: 300;
    color: var(--col-text);
    max-width: 580px;
    margin-bottom: 28px;
    line-height: 1.6;
    min-height: 3.2em;
  }

  .highlight-cyan {
    color: var(--col-neon-cyan);
  }

  /* ── Tags ── */
  .hero-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 36px;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.64rem;
    color: var(--col-neon-cyan);
    border: 1px solid rgba(0, 212, 255, 0.2);
    padding: 4px 14px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    background: rgba(0, 212, 255, 0.04);
    transition: all 0.3s ease;
  }

  .tag:hover {
    background: rgba(0, 212, 255, 0.1);
    border-color: rgba(0, 212, 255, 0.4);
  }

  /* ── CTA ── */
  .hero-cta {
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }

  .cta-primary {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 14px 32px;
    border: 1px solid var(--col-neon-green);
    color: var(--col-neon-green);
    background: rgba(0, 255, 65, 0.06);
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .cta-primary:hover {
    background: rgba(0, 255, 65, 0.14);
    box-shadow:
      0 0 30px rgba(0, 255, 65, 0.18),
      inset 0 0 30px rgba(0, 255, 65, 0.06);
    color: var(--col-neon-green);
  }

  .cta-secondary {
    font-family: var(--font-mono);
    font-size: 0.73rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--col-neon-cyan);
    padding: 14px 24px;
    border: 1px solid rgba(0,212,255,0.2);
    background: rgba(0,212,255,0.04);
    transition: all 0.3s ease;
  }

  .cta-secondary:hover {
    background: rgba(0,212,255,0.1);
    border-color: rgba(0,212,255,0.35);
    color: var(--col-neon-cyan);
  }

  .cta-tertiary {
    font-family: var(--font-mono);
    font-size: 0.73rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--col-text-dim);
    transition: color 0.2s;
  }

  .cta-tertiary:hover {
    color: var(--col-neon-cyan);
  }

  /* ── Data strip ── */
  .data-strip {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    overflow: hidden;
    border-top: 1px solid var(--col-border);
    background: rgba(10, 10, 12, 0.75);
    padding: 6px 0;
    z-index: 3;
  }

  .data-strip-inner {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    color: var(--col-text-dim);
    letter-spacing: 0.2em;
    white-space: nowrap;
    animation: scroll-strip 35s linear infinite;
  }

  @keyframes scroll-strip {
    to { transform: translateX(-50%); }
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .side-readout {
      display: none;
    }

    .corner {
      width: 18px;
      height: 18px;
    }

    .corner--bl, .corner--br {
      bottom: 40px;
    }

    .hero-cta {
      flex-direction: column;
      align-items: flex-start;
      gap: 14px;
    }

    .boot-sequence {
      margin-bottom: 20px;
    }

    .boot-line {
      font-size: 0.6rem;
    }

    .hud-line {
      display: none;
    }
  }
</style>
