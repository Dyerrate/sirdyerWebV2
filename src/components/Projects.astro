      pretextCtx.fillRect(0, 0, pretextCanvas.width, pretextCanvas.height);

      pretextCtx.font = `${PRETEXT_FONT_SIZE}px "Share Tech Mono", monospace`;
      pretextCtx.fillStyle = "#00ffff";
      pretextCtx.textBaseline = "top";

      const chars = PRETEXT_TEXT.replace(/\s/g, '').split("");
      const charWidth = PRETEXT_FONT_SIZE * 0.6; // monospace char width
      let charIndex = 0;
      let y = 8;

      // Layout text character by character, wrapping around the umbrella
      while (y < pretextCanvas.height - LINE_HEIGHT && charIndex < chars.length) {
        const segments = getLineBounds(y + PRETEXT_FONT_SIZE / 2);
        
        for (const segment of segments) {
          let x = segment.left;
          const maxX = segment.right;
          
          while (charIndex < chars.length && x + charWidth <= maxX) {
            const char = chars[charIndex % chars.length];
            
            // Rain effect: vertical streaks of brightness falling north to south
            const rainSpeed = 120; // faster fall speed
            const rainSpacing = 12; // tighter columns for more drops
            const rainLength = 40; // shorter streaks for more distinct drops
            
            // Calculate which "rain column" this character is in
            const rainColumn = Math.floor(x / rainSpacing);
            // Use a hash-like offset based on column to randomize start positions
            // but keep each column's rain falling straight down (no diagonal sweep)
            const columnSeed = (rainColumn * 137) % 100; // pseudo-random per column
            const rainY = ((rainTime * rainSpeed + columnSeed * 4) % (pretextCanvas.height + rainLength * 2)) - rainLength;
            
            // Distance from current y to the rain drop center
            const distFromRain = Math.abs(y - rainY);
            
            // Brightness based on proximity to rain drop
            let brightness = 0.2; // base dim
            if (distFromRain < rainLength) {
              // Gradient: dim at top of drop, bright at bottom (leading edge)
              const posInDrop = (y - (rainY - rainLength)) / rainLength;
              brightness = 0.2 + Math.max(0, posInDrop) * 0.6;
              
              // Extra bright at the very leading edge (bottom tip of drop)
              if (y > rainY && distFromRain < 8) {
                brightness = 1.0;
              }
            }
            
            const g = Math.floor(255 * brightness);
            const b = Math.floor(255 * brightness);
            pretextCtx.fillStyle = `rgb(0, ${g}, ${b})`;
            
            pretextCtx.fillText(char, x, y);
            x += charWidth;
            charIndex++;
          }
