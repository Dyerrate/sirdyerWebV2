      { lat: 0.30, lon: 1.60, r: 0.30, s: 0.75 }, // India/SE Asia
      { lat: -0.45, lon: 2.35, r: 0.28, s: 0.70 }, // Australia
      { lat: -1.25, lon: 0.0, r: 0.45, s: 0.55 }, // Antarctica
    ];

    function landScore(lat: number, lon: number): number {
      let best = 0;
      for (const c of CONTINENTS) {
        const cosD =
          Math.sin(lat) * Math.sin(c.lat) +
          Math.cos(lat) * Math.cos(c.lat) * Math.cos(lon - c.lon);
        const gd = Math.acos(Math.max(-1, Math.min(1, cosD)));
        const f = Math.max(0, 1 - gd / c.r) * c.s;
        if (f > best) best = f;
      }
      // Layered noise for ragged coastlines
      const n =
        Math.sin(lat * 8 + lon * 5) * 0.055 +
        Math.cos(lat * 11 - lon * 7) * 0.045 +
        Math.sin(lat * 17 + lon * 13) * 0.035;
      return best + n;
    }

    function buildGlobePoints(): THREE.BufferGeometry {
      const TOTAL = 18000;
      const pos: number[] = [];
      const col: number[] = [];
      const COAST = { r: 1.0, g: 1.0, b: 1.0 };
      const LAND = { r: 1.0, g: 0.82, b: 0.55 };
      const OCEAN = { r: 0.32, g: 0.18, b: 0.06 };

      for (let i = 0; i < TOTAL; i++) {
        const y = 1 - (i / (TOTAL - 1)) * 2;
        const rad = Math.sqrt(1 - y * y);
        const theta = i * Math.PI * (3 - Math.sqrt(5));
        const x = Math.cos(theta) * rad;
        const z = Math.sin(theta) * rad;

        const lat = Math.asin(y);
        const lon = Math.atan2(z, x);
        const score = landScore(lat, lon);
        const rnd = Math.random();

        let c: { r: number; g: number; b: number };
        if (score > 0.55) {
          if (rnd < 0.35) continue;
          c = LAND;
        } else if (score > 0.47) {
          c = COAST;
        } else if (score > 0.40) {
          if (rnd < 0.65) continue;
          c = LAND;
        } else {
          if (rnd < 0.965) continue;
          c = OCEAN;
        }
        pos.push(x, y, z);
        col.push(c.r, c.g, c.b);
      }

      const geom = new THREE.BufferGeometry();
      geom.setAttribute("position", new THREE.Float32BufferAttribute(pos, 3));
      geom.setAttribute("color", new THREE.Float32BufferAttribute(col, 3));
      return geom;
    }

    function initConnectz() {
      const parent = connectzCanvas.parentElement;
      if (!parent) return;
      const rect = parent.getBoundingClientRect();
      if (rect.width === 0 || rect.height === 0) return;

      if (!cRenderer) {
        cRenderer = new THREE.WebGLRenderer({
          canvas: connectzCanvas,
          antialias: true,
          alpha: false,
        });
        cRenderer.setClearColor(0x05040a, 1);
      }
      cRenderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 2));
      cRenderer.setSize(rect.width, rect.height, true);

      if (!cScene) {
        cScene = new THREE.Scene();
        cCamera = new THREE.PerspectiveCamera(36, rect.width / rect.height, 0.1, 100);
        cCamera.position.set(0, 0.35, 3.6);
        cCamera.lookAt(0, 0, 0);

        cGlobeGroup = new THREE.Group();
        cGlobeGroup.rotation.z = -0.32; // axial tilt
        cScene.add(cGlobeGroup);

        const globeGeom = buildGlobePoints();
        const globeMat = new THREE.PointsMaterial({
          size: 0.022,
          vertexColors: true,
          sizeAttenuation: true,
          transparent: true,
          opacity: 0.95,
          depthWrite: false,
        });
        const globe = new THREE.Points(globeGeom, globeMat);
        cGlobeGroup.add(globe);

        // Satellites
        const satPos = new Float32Array(cSats.length * 3);
        cSatGeom = new THREE.BufferGeometry();
        cSatGeom.setAttribute("position", new THREE.BufferAttribute(satPos, 3));
        const satMat = new THREE.PointsMaterial({
          color: 0xffd88a,
          size: 0.045,
          sizeAttenuation: true,
          transparent: true,
          opacity: 1,
          depthWrite: false,
        });
        const satellites = new THREE.Points(cSatGeom, satMat);
        satellites.frustumCulled = false;
        cScene.add(satellites);

        // Distant starfield behind the globe
        const STAR_COUNT = 500;
        const starPos = new Float32Array(STAR_COUNT * 3);
        for (let i = 0; i < STAR_COUNT; i++) {
          const u = Math.random() * 2 - 1;
          const t = Math.random() * Math.PI * 2;
          const sr = Math.sqrt(1 - u * u);
          const R = 25;
          starPos[i * 3] = Math.cos(t) * sr * R;
          starPos[i * 3 + 1] = u * R;
          starPos[i * 3 + 2] = Math.sin(t) * sr * R;
        }
        const starGeom = new THREE.BufferGeometry();
        starGeom.setAttribute("position", new THREE.BufferAttribute(starPos, 3));
        const starMat = new THREE.PointsMaterial({
          color: 0xff9c55,
          size: 0.9,
          sizeAttenuation: false,
          transparent: true,
          opacity: 0.25,
          depthWrite: false,
        });
        cScene.add(new THREE.Points(starGeom, starMat));
      } else if (cCamera) {
        cCamera.aspect = rect.width / rect.height;
        cCamera.updateProjectionMatrix();
      }
    }

    function drawConnectz() {
      if (!cRenderer || !cScene || !cCamera || !cGlobeGroup) return;
      connectzT += 0.01;
      cGlobeGroup.rotation.y = connectzT * 0.35;

      if (cSatGeom) {
        const posAttr = cSatGeom.getAttribute("position") as THREE.BufferAttribute;
        const arr = posAttr.array as Float32Array;
        for (let i = 0; i < cSats.length; i++) {
          const s = cSats[i];
          const a = connectzT * s.speed + s.phase;
          const ox = Math.cos(a) * s.orbitR;
          const oz = Math.sin(a) * s.orbitR;
          arr[i * 3] = ox;
          arr[i * 3 + 1] = oz * Math.sin(s.tilt);
          arr[i * 3 + 2] = oz * Math.cos(s.tilt);
        }
        posAttr.needsUpdate = true;
      }

      cRenderer.render(cScene, cCamera);
      if (connectzRunning) {
        connectzAnimationId = requestAnimationFrame(drawConnectz);
      }
    }

    startConnectz = function () {
      if (connectzRunning) return;
      connectzRunning = true;
      initConnectz();
      drawConnectz();
    };

    stopConnectz = function () {
      connectzRunning = false;
      if (connectzAnimationId) {
        cancelAnimationFrame(connectzAnimationId);
        connectzAnimationId = null;
      }
    };
  });
</script>

